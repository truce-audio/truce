# truce plugin project configuration
# Copy this file to truce.toml and edit for your project.
#
# Plugin metadata comes from this file (+ Cargo.toml for version fallback):
#   - vendor name, url, AU manufacturer: [vendor] section
#   - plugin-specific IDs: [[plugin]] sections
#   - version: per-plugin "version" field, or CARGO_PKG_VERSION if omitted
#
# Build environment (signing, SDK paths) is configured via env vars:
#   TRUCE_SIGNING_IDENTITY           code signing identity (default: "-" for ad-hoc)
#   TRUCE_INSTALLER_SIGNING_IDENTITY installer signing identity (for .pkg)
#   AAX_SDK_PATH                     path to AAX SDK root
#
# Set these in your shell profile or .cargo/config.toml (not committed):
#   [env]
#   TRUCE_SIGNING_IDENTITY = "Developer ID Application: Your Name (TEAMID)"

[vendor]
name = "My Company"
id = "com.mycompany"
url = "https://mycompany.com"
au_manufacturer = "MyCo"

# Each [[plugin]] entry defines a plugin to build and install.

[[plugin]]
name = "My Effect"
suffix = "effect"
crate = "my-effect"
# version = "1.0.0"              # optional, defaults to Cargo.toml version
category = "effect"               # "effect", "instrument", or "midi"
fourcc = "MyFx"                   # 4-char plugin identifier (AU, VST2, AAX)
# au3_subtype = "MyF3"           # optional 4-char AU v3 subtype (defaults to fourcc)
# au_tag = "Effects"             # AU category tag: Effects, EQ, Dynamics,
                                  #   Delay, Distortion, Reverb, Synthesizer,
                                  #   Sampler, Pitch
# aax_category = "Dynamics"      # AAX category: EQ, Dynamics, PitchShift,
                                  #   Reverb, Delay, Modulation, Harmonic,
                                  #   NoiseReduction, Dither, SoundField

# [[plugin]]
# name = "My Synth"
# suffix = "synth"
# crate = "my-synth"
# fourcc = "MySn"
# category = "instrument"
# au_tag = "Synthesizer"
# aax_category = "Synthesizer"

# --- Optional: override build env vars in truce.toml ---
# Uncomment to override the env var defaults. Not recommended for
# shared repos — use env vars instead.
#
# [macos]
# signing_identity = "Developer ID Application: Your Name (TEAMID)"
# aax_sdk_path = "/path/to/aax-sdk"
#
# [macos.packaging]
# installer_identity = "Developer ID Installer: Your Name (TEAMID)"

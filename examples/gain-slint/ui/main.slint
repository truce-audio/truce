import { Knob, Meter, XYPad } from "@truce";
import { HorizontalBox } from "std-widgets.slint";
import "JetBrainsMono-Regular.ttf";

export component GainUi inherits Window {
    in-out property <float> gain: 0.5;
    in-out property <float> pan: 0.5;
    in-out property <float> meter-left: 0.0;
    in-out property <float> meter-right: 0.0;

    callback gain-changed(float);
    callback pan-changed(float);

    title: "GAIN (slint)";
    preferred-width: 190px;
    preferred-height: 310px;
    background: #1f1f24;
    default-font-family: "JetBrains Mono";

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 10px;
        alignment: start;

        Text {
            text: "GAIN (slint)";
            font-size: 14px;
            font-weight: 700;
            color: #e6e6eb;
            horizontal-alignment: left;
        }

        Rectangle {
            height: 1px;
            background: #3a3a44;
        }

        HorizontalLayout {
            spacing: 10px;

            VerticalLayout {
                spacing: 10px;

                HorizontalLayout {
                    spacing: 10px;

                    Knob {
                        label: "Gain";
                        value <=> root.gain;
                        changed(v) => { root.gain-changed(v); }
                    }

                    Knob {
                        label: "Pan";
                        value <=> root.pan;
                        changed(v) => { root.pan-changed(v); }
                    }
                }

                XYPad {
                    width: 130px;
                    height: 147px;
                    label: "Pan / Gain";
                    value-x <=> root.pan;
                    value-y <=> root.gain;
                    changed-x(v) => { root.pan-changed(v); }
                    changed-y(v) => { root.gain-changed(v); }
                }
            }

            Meter {
                height: 247px;
                level-left: root.meter-left;
                level-right: root.meter-right;
                label: "Level";
            }
        }
    }
}

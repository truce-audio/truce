import { Knob, Meter, ParamSlider, Toggle } from "@truce";
import { HorizontalBox } from "std-widgets.slint";

export component GainUi inherits Window {
    in-out property <float> gain: 0.5;
    in-out property <float> pan: 0.5;
    in-out property <bool> bypass: false;
    in-out property <float> meter-left: 0.0;
    in-out property <float> meter-right: 0.0;

    callback gain-changed(float);
    callback pan-changed(float);
    callback bypass-changed(bool);

    title: "Gain (slint)";
    preferred-width: 380px;
    preferred-height: 160px;
    background: #1f1f24;
    default-font-family: "JetBrains Mono";

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 6px;
        padding-bottom: 6px;
        spacing: 4px;
        alignment: start;

        Text {
            text: "Gain (slint)";
            font-size: 14px;
            font-weight: 700;
            color: #e6e6eb;
            horizontal-alignment: center;
        }

        Rectangle {
            height: 1px;
            background: #3a3a44;
        }

        HorizontalBox {
            alignment: center;
            spacing: 12px;

            Knob {
                label: "Gain";
                value <=> root.gain;
                changed(v) => { root.gain-changed(v); }
            }

            ParamSlider {
                width: 120px;
                label: "Pan";
                value <=> root.pan;
                changed(v) => { root.pan-changed(v); }
            }

            Toggle {
                label: "Bypass";
                checked <=> root.bypass;
                toggled(v) => { root.bypass-changed(v); }
            }

            Meter {
                level-left: root.meter-left;
                level-right: root.meter-right;
                label: "Level";
            }
        }
    }
}

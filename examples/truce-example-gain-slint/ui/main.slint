import { Knob, Meter, XYPad } from "@truce";
import { HorizontalBox } from "std-widgets.slint";
import "JetBrainsMono-Regular.ttf";

export component GainUi inherits Window {
    in-out property <float> gain: 0.5;
    in-out property <float> pan: 0.5;
    in-out property <string> gain-text: "";
    in-out property <string> pan-text: "";
    in-out property <float> meter-left: 0.0;
    in-out property <float> meter-right: 0.0;

    callback gain-changed(float);
    callback pan-changed(float);

    title: "GAIN (slint)";
    preferred-width: 176px;
    preferred-height: 290px;
    background: #1f1f24;
    default-font-family: "JetBrains Mono";

    VerticalLayout {
        spacing: 0px;
        alignment: start;

        // Header — 30px, matches egui/iced
        Rectangle {
            height: 30px;
            background: #14141a;

            Text {
                x: 10px;
                y: (parent.height - self.preferred-height) / 2;
                text: "GAIN (slint)";
                font-size: 14px;
                font-weight: 700;
                color: #bfbfc8;
            }
        }

        // Content area with 10px padding
        VerticalLayout {
            padding-left: 10px;
            padding-right: 10px;
            padding-top: 10px;
            padding-bottom: 10px;

            HorizontalLayout {
                spacing: 10px;

                VerticalLayout {
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 10px;

                        Knob {
                            label: "Gain";
                            value <=> root.gain;
                            value-text: root.gain-text;
                            changed(v) => { root.gain-changed(v); }
                        }

                        Knob {
                            label: "Pan";
                            value <=> root.pan;
                            value-text: root.pan-text;
                            changed(v) => { root.pan-changed(v); }
                        }
                    }

                    XYPad {
                        width: 130px;
                        label: "Pan / Gain";
                        value-x <=> root.pan;
                        value-y <=> root.gain;
                        changed-x(v) => { root.pan-changed(v); }
                        changed-y(v) => { root.gain-changed(v); }
                    }
                }

                Meter {
                    height: 222px;
                    level-left: root.meter-left;
                    level-right: root.meter-right;
                }
            }
        }
    }
}

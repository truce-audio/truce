// Vertical level meter (display-only).

export component Meter inherits Rectangle {
    in property <float> level-left: 0.0;
    in property <float> level-right: 0.0;

    width: 16px;
    height: 100px;

    // Meter bars
    HorizontalLayout {
        padding-left: 1px;
        padding-right: 1px;
        padding-top: 0px;
        padding-bottom: 0px;
        spacing: 2px;

        // Left channel
        Rectangle {
            background: #2a2a30;
            border-radius: 2px;
            clip: true;

            property <float> lv: clamp(root.level-left, 0, 1);
            Rectangle {
                y: parent.height * (1.0 - lv);
                height: parent.height * lv;
                background: lv > 0.95 ? #e04545 : #4d99f2;
                border-radius: 2px;
            }
        }

        // Right channel
        Rectangle {
            background: #2a2a30;
            border-radius: 2px;
            clip: true;

            property <float> rv: clamp(root.level-right, 0, 1);
            Rectangle {
                y: parent.height * (1.0 - rv);
                height: parent.height * rv;
                background: rv > 0.95 ? #e04545 : #4d99f2;
                border-radius: 2px;
            }
        }
    }
}

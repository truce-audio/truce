// Rotary knob with 270-degree arc, pointer line, and hover highlight.
// Drag vertically to change value.

export component Knob inherits Rectangle {
    in-out property <float> value: 0.5;
    in property <string> label: "";
    in property <string> value-text: "";
    in property <float> minimum: 0.0;
    in property <float> maximum: 1.0;

    in property <color> track-color: #3a3a44;
    in property <color> fill-color: #4d99f2;
    in property <color> pointer-color: #f2f2f7;
    in property <color> hover-color: #737373;
    in property <color> label-color: #8c8c99;
    in property <color> value-color: #e6e6eb;

    callback changed(float);

    width: 60px;
    height: 82px;

    property <float> norm: (value - minimum) / (maximum - minimum);
    property <float> val-angle: 135 + norm * 270;

    // Arc geometry: center (30,30), radius 25, in a 60x60 coordinate space.
    pure function ax(a: float) -> float { 30 + 25 * cos(a * 1deg) }
    pure function ay(a: float) -> float { 30 + 25 * sin(a * 1deg) }

    // Pointer line endpoints (center to 60% of radius toward arc)
    pure function ptr-len() -> float { 25 * 0.6 }

    // Hover highlight ring (slightly outside the track arc)
    Path {
        x: (parent.width - 60px) / 2;
        y: 5px;
        width: 60px;
        height: 60px;
        viewbox-x: 0; viewbox-y: 0;
        viewbox-width: 60; viewbox-height: 60;
        stroke: touch.has-hover ? root.hover-color : transparent;
        stroke-width: 1.5px;

        MoveTo { x: 30 + 28 * cos(135deg); y: 30 + 28 * sin(135deg); }
        ArcTo {
            x: 30 + 28 * cos(405deg); y: 30 + 28 * sin(405deg);
            radius-x: 28; radius-y: 28;
            sweep: true; large-arc: true;
        }
    }

    // Track arc (full 270 degrees)
    Path {
        x: (parent.width - 60px) / 2;
        y: 5px;
        width: 60px;
        height: 60px;
        viewbox-x: 0; viewbox-y: 0;
        viewbox-width: 60; viewbox-height: 60;
        stroke: root.track-color;
        stroke-width: 3px;

        MoveTo { x: ax(135); y: ay(135); }
        ArcTo {
            x: ax(405); y: ay(405);
            radius-x: 25; radius-y: 25;
            sweep: true; large-arc: true;
        }
    }

    // Value arc
    Path {
        x: (parent.width - 60px) / 2;
        y: 5px;
        width: 60px;
        height: 60px;
        viewbox-x: 0; viewbox-y: 0;
        viewbox-width: 60; viewbox-height: 60;
        stroke: root.fill-color;
        stroke-width: 3px;

        MoveTo { x: ax(135); y: ay(135); }
        ArcTo {
            x: ax(root.val-angle); y: ay(root.val-angle);
            radius-x: 25; radius-y: 25;
            sweep: true;
            large-arc: root.norm > 0.667;
        }
    }

    // Pointer line (center to value position)
    Path {
        x: (parent.width - 60px) / 2;
        y: 5px;
        width: 60px;
        height: 60px;
        viewbox-x: 0; viewbox-y: 0;
        viewbox-width: 60; viewbox-height: 60;
        stroke: root.pointer-color;
        stroke-width: 2px;

        MoveTo { x: 30; y: 30; }
        LineTo {
            x: 30 + ptr-len() * cos(root.val-angle * 1deg);
            y: 30 + ptr-len() * sin(root.val-angle * 1deg);
        }
    }

    // Value text (below knob arc)
    Text {
        y: 57px;
        width: parent.width;
        text: root.value-text != "" ? root.value-text : round(root.value * 100) / 100;
        font-size: 10px;
        color: root.value-color;
        horizontal-alignment: center;
    }

    // Label
    Text {
        y: 69px;
        width: parent.width;
        text: root.label;
        font-size: 10px;
        color: root.label-color;
        horizontal-alignment: center;
    }

    // Drag interaction
    touch := TouchArea {
        width: parent.width;
        height: 70px;
        property <float> start-value;

        pointer-event(ev) => {
            if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                start-value = root.value;
            }
        }
        moved => {
            if self.pressed {
                root.value = clamp(
                    start-value - (touch.mouse-y - touch.pressed-y) / 150px * (root.maximum - root.minimum),
                    root.minimum, root.maximum,
                );
                root.changed(root.value);
            }
        }
    }
}

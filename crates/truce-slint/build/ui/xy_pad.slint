// XY pad - 2D control for two parameters.
// Drag anywhere to set both X and Y values simultaneously.

export component XYPad inherits VerticalLayout {
    in-out property <float> value-x: 0.5;
    in-out property <float> value-y: 0.5;
    in property <string> label: "";

    // True while the pad is being dragged. A host that mirrors the
    // param back into `value-x` / `value-y` every frame should skip
    // that write-back while this is set, so the round-trip
    // (`normalize(denormalize(v))` - lossy on log/stepped ranges,
    // worst at the clamped edges) can't fight the live drag.
    out property <bool> dragging: touch.pressed;

    callback changed-x(float);
    callback changed-y(float);
    // Gesture boundaries. `pressed` fires on pointer-down (before the
    // first `changed-*`), `released` on pointer-up/cancel, so the host
    // sees one automation gesture spanning the whole drag - `begin_edit`
    // on press, `end_edit` on release - instead of a fresh open/close per
    // move that lets read-mode automation reclaim the param between moves.
    callback pressed();
    callback released();

    // `preferred-*` lets a parent layout stretch the pad in both
    // axes. `min-*` keeps the pad usable when the editor window
    // shrinks to its minimum size.
    min-width: 80px;
    min-height: 90px;
    preferred-width: 120px;
    preferred-height: 132px;
    spacing: 2px;

    pad := Rectangle {
        // No explicit `width`/`height` - the parent
        // `VerticalLayout` gives the pad the full width and any
        // vertical space the label below doesn't claim, which
        // lets the pad grow with the editor window. The
        // `vertical-stretch: 1` makes the pad the one item that
        // absorbs extra height (the label keeps its text
        // height).
        vertical-stretch: 1;
        background: #2e2e38;
        border-color: #737373;
        border-width: 1px;
        // Keep the dot and crosshairs inside the border: they're
        // centered on the value, so at the extremes (and both axes at a
        // corner) they'd otherwise overflow the pad.
        clip: true;

        property <length> dot-x: pad.width * root.value-x;
        property <length> dot-y: pad.height * (1.0 - root.value-y);

        // Crosshair lines (30% opacity accent)
        Rectangle {
            x: pad.dot-x - 0.5px;
            y: 0px;
            width: 1px;
            height: pad.height;
            background: rgba(77, 153, 242, 0.3);
        }
        Rectangle {
            x: 0px;
            y: pad.dot-y - 0.5px;
            width: pad.width;
            height: 1px;
            background: rgba(77, 153, 242, 0.3);
        }

        // Dot
        Rectangle {
            x: pad.dot-x - 5px;
            y: pad.dot-y - 5px;
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: #4d99f2;
        }

        // Drag interaction
        touch := TouchArea {
            width: pad.width;
            height: pad.height;
            // Tracks an in-flight left-button gesture so `released` pairs
            // with `pressed` exactly once (an `up`/`cancel` with no prior
            // left `down` is ignored).
            property <bool> gesture-active: false;

            moved => {
                if self.pressed {
                    root.value-x = clamp(touch.mouse-x / pad.width, 0.0, 1.0);
                    root.value-y = clamp(1.0 - touch.mouse-y / pad.height, 0.0, 1.0);
                    root.changed-x(root.value-x);
                    root.changed-y(root.value-y);
                }
            }

            pointer-event(ev) => {
                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                    self.gesture-active = true;
                    root.pressed();
                    root.value-x = clamp(touch.mouse-x / pad.width, 0.0, 1.0);
                    root.value-y = clamp(1.0 - touch.mouse-y / pad.height, 0.0, 1.0);
                    root.changed-x(root.value-x);
                    root.changed-y(root.value-y);
                } else if self.gesture-active
                        && (ev.kind == PointerEventKind.up || ev.kind == PointerEventKind.cancel) {
                    self.gesture-active = false;
                    root.released();
                }
            }
        }
    }

    // Label - `VerticalLayout` already takes the row's full
    // width, so an explicit `width: root.width` would form a
    // binding loop (width <-> layout-info).
    Text {
        text: root.label;
        font-size: 10px;
        color: #8c8c99;
        horizontal-alignment: center;
    }
}
